---
extends: default

ignore: [taskfiles/**, .taskotter/**]

rules:
  comments:
    min-spaces-from-content: 1

  comments-indentation: false

  braces:
    min-spaces-inside: 0
    max-spaces-inside: 1

  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true

  line-length:
    max: 140
    level: warning

  truthy:
    allowed-values: ["true", "false", "on", "off", "yes", "no"]
